{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**", "out/**"]
        },
        "typecheck": {
            "dependsOn": ["^build"]
        },
        "test": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "dev:lan": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true,
            "env": ["HOST", "CORS_ORIGIN", "NEXT_PUBLIC_RUNNER_URL"]
        },
        "clean": {
            "cache": false
        }
    }
}
