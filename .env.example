# Fabritorio runner config — all optional; the runner boots with no .env.
# Everything here populates process.env. Model API keys are resolved by the
# name each Model node's `auth_env` field references (default OPENAI_API_KEY).
# Local endpoints (Ollama, vLLM, LM Studio) need no key — set the Model node's
# `base_url` in the inspector instead.

# Hosted-model API keys — set whichever provider(s) you use.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Server (defaults shown)
# PORT=4000
# CORS_ORIGIN=http://localhost:3000
