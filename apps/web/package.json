{
    "name": "@fabritorio/web",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev --port 3000",
        "dev:lan": "next dev --port 3000 --hostname 0.0.0.0",
        "build": "NEXT_OUTPUT_EXPORT=1 next build",
