        "clean": "rm -rf .next .turbo *.tsbuildinfo"
    },
    "dependencies": {
        "@fabritorio/types": "workspace:*",
        "@xyflow/react": "^12.3.6",
        "highlight.js": "^11.11.1",
        "katex": "^0.16.47",
        "next": "^15.1.6",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-markdown": "^10.1.0",
        "rehype-highlight": "^7.0.2",
        "rehype-katex": "^7.0.1",
        "remark-gfm": "^4.0.1",
        "remark-math": "^6.0.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.0.0",
        "@types/node": "^22.10.5",
        "@types/react": "^19.0.7",
        "@types/react-dom": "^19.0.3",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
