{
    "name": "@fabritorio/runner",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "bash ../../scripts/freeport.sh && tsx watch src/index.ts",
        "dev:lan": "bash ../../scripts/freeport.sh && tsx watch src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/index.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run",
        "clean": "rm -rf dist .turbo *.tsbuildinfo"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "0.91.1",
        "@fabritorio/types": "workspace:*",
        "@fastify/cors": "^10.0.1",
        "@fastify/static": "^9.1.3",
        "@google/genai": "^2.6.0",
        "@mozilla/readability": "^0.6.0",
        "cheerio": "^1.2.0",
        "croner": "^9.1.0",
        "dotenv": "^16.4.7",
        "fastify": "^5.2.1",
        "gray-matter": "^4.0.3",
        "linkedom": "^0.18.12",
        "openai": "^4.80.0",
        "turndown": "^7.2.4"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "@types/turndown": "^5.0.6",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
}
